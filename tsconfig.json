{
  "compilerOptions": {
    "target": "ES2020",               // Specify ECMAScript target version
    "module": "commonjs",              // Use commonjs module system (default for Node.js)
    "outDir": "./dist",                // Directory where the compiled JavaScript will go
    "rootDir": "./src",                // Root directory for TypeScript files
    "strict": true,                    // Enable strict type-checking
    "esModuleInterop": true,           // Allows default import syntax
    "skipLibCheck": true,              // Skip type checking of declaration files (useful for faster compilation)
    "forceConsistentCasingInFileNames": true  // Ensures consistent file name casing
  },
  "include": [
    "src/**/*.ts"                      // Include all TypeScript files under the 'src' directory
  ],
  "exclude": [
    "node_modules"                     // Exclude node_modules
  ]
}
